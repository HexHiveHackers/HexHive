# Dependencies
node_modules/

# SvelteKit / Vite output
.svelte-kit/
build/
dist/
.vite/

# Env files (only .env.example is committed)
.env
.env.*
!.env.example

# Local databases (SQLite + WAL/SHM sidecars)
/local.db
/local.db-journal
/local.db-shm
/local.db-wal

# Dev-only filesystem storage fallback (when R2 isn't configured)
/.dev-storage/
*.sqlite
*.sqlite-shm
*.sqlite-wal

# Test output
/coverage/
/.nyc_output/
/playwright-report/
/test-results/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/

# Emacs (backups, autosaves, lock files)
*~
.#*
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# Vim
*.swp
*.swo
*.swn

# TypeScript incremental build info
*.tsbuildinfo

# Bun
.bun/

# Playwright
/e2e/test-results/
/e2e/playwright-report/
/e2e/.auth/

# Optional: deployed-platform caches
.vercel/
.netlify/

